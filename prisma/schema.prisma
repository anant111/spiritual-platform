generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Bookmark {
  id        String   @id @default(cuid())
  videoId   String
  title     String
  thumbnail String
  channel   String
  createdAt DateTime @default(now())

  @@index([videoId])
}

model Reflection {
  id        String   @id @default(cuid())
  content   String
  videoId   String?
  createdAt DateTime @default(now())
}
